<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

    <!-- Required: location permission string shown to the user -->
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>ThemeCast uses your location to show weather with themed visuals for your area.</string>

    <!-- App display name -->
    <key>CFBundleDisplayName</key>
    <string>ThemeCast</string>

    <!-- Supported orientations (portrait only for a weather app) -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>

    <!-- iOS 16+ scene configuration (SwiftUI lifecycle) -->
    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <false/>
    </dict>

</dict>
</plist>
